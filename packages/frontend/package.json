{
    "name": "arpa-chatbot",
    "displayName": "ARPA Chatbot",
    "version": "0.0.1",
    "description": "AI-powered chatbot interface for VSCode using OpenAI API",
    "publisher": "YuTengjing",
    "private": true,
    "preview": true,
    "author": {
        "name": "YuTengjing",
        "email": "ytj2713151713@gmail.com",
        "url": "https://github.com/tjx666"
    },
    "license": "SEE LICENSE IN LICENSE",
    "homepage": "https://github.com/tjx666/awesome-vscode-extension-boilerplate/blob/master/README.md",
    "repository": {
        "type": "git",
        "url": "https://github.com/tjx666/awesome-vscode-extension-boilerplate"
    },
    "bugs": {
        "url": "https://github.com/tjx666/awesome-vscode-extension-boilerplate/issues",
        "email": "ytj2713151713@gmail.com"
    },
    "keywords": [
        "boilerplate",
        "template"
    ],
    "categories": [
        "Other"
    ],
    "main": "./out/src/extension.js",
    "icon": "assets/logo.png",
    "packageManager": "bun@1.0.0",
    "engines": {
        "vscode": "^1.90.0"
    },
    "badges": [
        {
            "url": "https://img.shields.io/badge/PRs-welcome-brightgreen.svg",
            "description": "PRs Welcome",
            "href": "https://github.com/tjx666/awesome-vscode-extension-boilerplate/fork"
        }
    ],
    "activationEvents": [
        "onCommand:arpa-chatbot.openChatbot"
    ],
    "contributes": {
        "commands": [
            {
                "command": "arpa-chatbot.openChatbot",
                "title": "ARPA: Open Chatbot",
                "icon": "$(comment-discussion)"
            }
        ],
        "configuration": {
            "title": "ARPA Chatbot",
            "properties": {
                "arpa-chatbot.openaiApiKey": {
                    "type": "string",
                    "default": "",
                    "description": "OpenAI API Key for chatbot functionality"
                },
                "arpa-chatbot.model": {
                    "type": "string",
                    "default": "gpt-3.5-turbo",
                    "description": "OpenAI model to use",
                    "enum": ["gpt-3.5-turbo", "gpt-4", "gpt-4-turbo"]
                }
            }
        }
    },
    "eslintConfig": {
        "extends": "@yutengjing/eslint-config-typescript",
        "ignorePatterns": [
            "test-workspace"
        ]
    },
    "prettier": "@yutengjing/prettier-config",
    "lint-staged": {
        "*.{ts,json,md}": [
            "eslint --fix",
            "prettier --write"
        ]
    },
    "simple-git-hooks": {
        "pre-commit": "npx lint-staged"
    },
    "scripts": {
        "vscode:prepublish": "bun esbuild:base --minify",
        "preinstall": "npx only-allow bun",
        "postinstall": "stale-dep -u",
        "prepare": "simple-git-hooks",
        "clean": "npx rimraf -rf ./out",
        "esbuild:base": "bun scripts/esbuild.ts",
        "esbuild:watch": "bun esbuild:base --sourcemap --watch",
        "esbuild:analyze": "bun esbuild:base --minify --metafile --analyze && esbuild-visualizer --metadata ./meta.json --open",
        "compile:test": "bun clean && tsc -b ./test/tsconfig.json",
        "lint": "eslint src --ext ts",
        "test": "bun compile:test && node ./out/test/runTests.js",
        "package": "vsce package --no-dependencies",
        "release": "npx @yutengjing/release",
        "publish:vs-marketplace": "vsce publish --no-dependencies",
        "publish:open-vsx": "ovsx publish --no-dependencies"
    },
    "dependencies": {
        "openai": "^4.20.1",
        "dotenv": "^16.3.1",
        "convex": "^1.26.1"
    },
    "devDependencies": {
        "@types/glob": "^8.1.0",
        "@types/mocha": "^10.0.7",
        "@types/node": "~20.16.2",
        "@types/vscode": "1.90.0",
        "@vscode/test-electron": "^2.4.1",
        "@vscode/vsce": "^3.0.0",
        "@yutengjing/eslint-config-typescript": "^1.2.2",
        "@yutengjing/prettier-config": "^1.3.0",
        "@yutengjing/release": "^0.3.1",
        "esbuild": "~0.23.1",
        "esbuild-visualizer": "^0.6.0",
        "eslint": "^8.57.0",
        "glob": "^11.0.0",
        "lint-staged": "^15.2.9",
        "mocha": "^10.7.3",
        "ovsx": "^0.9.2",
        "prettier": "^3.3.3",
        "rimraf": "^6.0.1",
        "simple-git-hooks": "^2.11.1",
        "stale-dep": "^0.7.0",
        "tsx": "^4.19.0",
        "typescript": "~5.5.4"
    }
}
