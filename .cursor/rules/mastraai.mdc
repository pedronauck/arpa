## Error Handling & Resilience
- Implement exponential backoff with jitter
- Distinguish between error types
- Provide fallback behavior
- Log errors for monitoring
```typescript
// utils/ai-error-handler.ts
export class AIError extends Error {
  constructor(
    message: string,
    public code: string,
    public retryable: boolean,
    public statusCode?: number
  ) {
    super(message)
    this.name = 'AIError'
  }
}

export async function withRetry<T>(
  fn: () => Promise<T>,
  options: {
    maxAttempts?: number
    initialDelay?: number
    maxDelay?: number
    onRetry?: (attempt: number, error: Error) => void
  } = {}
): Promise<T> {
  const {
    maxAttempts = 3,
    initialDelay = 1000,
    maxDelay = 10000,
    onRetry,
  } = options

  let lastError: Error

  for (let attempt = 1; attempt <= maxAttempts; attempt++) {
    try {
      return await fn()
    } catch (error) {
      lastError = error as Error
      
      // Don't retry non-retryable errors
      if (error instanceof AIError && !error.retryable) {
        throw error
      }
      
      if (attempt < maxAttempts) {
        const delay = Math.min(
          initialDelay * Math.pow(2, attempt - 1) + Math.random() * 1000,
          maxDelay
        )
        
        onRetry?.(attempt, lastError)
        await new Promise(resolve => setTimeout(resolve, delay))
      }
    }
  }

  throw lastError!
}
```

## Rate Limiting & Quota Management
- Implement client-side rate limiting
- Track token usage per user/feature
- Queue requests during high load
- Monitor usage against quotas
```typescript
// services/rate-limiter.ts
interface RateLimiterOptions {
  maxRequests: number
  windowMs: number
  maxQueueSize?: number
}

export class TokenBucket {
  private tokens: number
  private lastRefill: number
  private queue: Array<() => void> = []

  constructor(
    private capacity: number,
    private refillRate: number,
    private maxQueueSize = 100
  ) {
    this.tokens = capacity
    this.lastRefill = Date.now()
  }

  async acquire(): Promise<void> {
    this.refill()

    if (this.tokens > 0) {
      this.tokens--
      return
    }

    // Queue if at capacity
    if (this.queue.length >= this.maxQueueSize) {
      throw new AIError(
        'Rate limit queue full',
        'QUEUE_FULL',
        false,
        429
      )
    }

    return new Promise((resolve) => {
      this.queue.push(resolve)
    })
  }

  private refill(): void {
    const now = Date.now()
    const timePassed = now - this.lastRefill
    const tokensToAdd = (timePassed / 1000) * this.refillRate
    
    this.tokens = Math.min(this.capacity, this.tokens + tokensToAdd)
    this.lastRefill = now

    // Process queue
    while (this.tokens > 0 && this.queue.length > 0) {
      this.tokens--
      const resolve = this.queue.shift()!
      resolve()
    }
  }
}

// Usage tracking
export class UsageTracker {
  private usage = new Map<string, { tokens: number; cost: number }>()

  track(userId: string, tokens: number, cost: number): void {
    const current = this.usage.get(userId) || { tokens: 0, cost: 0 }
    this.usage.set(userId, {
      tokens: current.tokens + tokens,
      cost: current.cost + cost,
    })
  }

  getUsage(userId: string): { tokens: number; cost: number } {
    return this.usage.get(userId) || { tokens: 0, cost: 0 }
  }
}
```

## Caching Strategies
- Cache by semantic similarity, not just exact matches
- Implement TTL based on data volatility
- Use Redis for distributed caching
- Monitor cache hit rates
```typescript
// services/ai-cache.ts
import { Redis } from 'ioredis'
import { createHash } from 'crypto'

export class AICache {
  constructor(
    private redis: Redis,
    private defaultTTL = 3600 // 1 hour
  ) {}

  private generateKey(
    prompt: string,
    model: string,
    params: Record<string, any>
  ): string {
    const hash = createHash('sha256')
    hash.update(prompt)
    hash.update(model)
    hash.update(JSON.stringify(params))
    return `ai:${hash.digest('hex')}`
  }

  async get<T>(
    prompt: string,
    model: string,
    params: Record<string, any>
  ): Promise<T | null> {
    const key = this.generateKey(prompt, model, params)
    const cached = await this.redis.get(key)
    
    if (cached) {
      // Update metrics
      await this.redis.hincrby('ai:metrics', 'cache_hits', 1)
      return JSON.parse(cached)
    }
    
    await this.redis.hincrby('ai:metrics', 'cache_misses', 1)
    return null
  }

  async set<T>(
    prompt: string,
    model: string,
    params: Record<string, any>,
    value: T,
    ttl?: number
  ): Promise<void> {
    const key = this.generateKey(prompt, model, params)
    await this.redis.setex(
      key,
      ttl || this.defaultTTL,
      JSON.stringify(value)
    )
  }

  // Semantic caching with embeddings
  async findSimilar(
    embedding: number[],
    threshold = 0.95
  ): Promise<any | null> {
    // Implementation depends on vector database
    // Example with pgvector or Redis Vector Search
    return null
  }
}
