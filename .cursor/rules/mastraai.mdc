## Cost Optimization
- Choose the right model for each task
- Implement prompt compression
- Cache aggressively
- Monitor and alert on usage spikes
```typescript
// services/cost-optimizer.ts
export class CostOptimizer {
  private modelCosts = {
    'gpt-3.5-turbo': { input: 0.0005, output: 0.0015 },
    'gpt-4': { input: 0.03, output: 0.06 },
    'gpt-4-turbo': { input: 0.01, output: 0.03 },
  }

  estimateCost(
    model: string,
    inputTokens: number,
    outputTokens: number
  ): number {
    const costs = this.modelCosts[model]
    if (!costs) return 0
    
    return (
      (inputTokens / 1000) * costs.input +
      (outputTokens / 1000) * costs.output
    )
  }

  compressPrompt(prompt: string): string {
    // Remove extra whitespace
    let compressed = prompt.replace(/\s+/g, ' ').trim()
    
    // Remove redundant instructions (be careful)
    compressed = compressed.replace(
      /please|could you|can you|would you/gi,
      ''
    )
    
    return compressed
  }

  async shouldUseCache(
    estimatedCost: number,
    cacheHitProbability: number
  ): Promise<boolean> {
    // Simple heuristic: cache if expected savings > cache overhead
    const cacheOverhead = 0.0001 // Redis cost estimate
    const expectedSavings = estimatedCost * cacheHitProbability
    
    return expectedSavings > cacheOverhead
  }
}
```

## Monitoring & Observability
- Track latency percentiles
- Monitor error rates by type
- Alert on anomalies
- Dashboard key metrics
```typescript
// services/ai-monitoring.ts
export class AIMonitoring {
  private metrics = {
    latency: new Map<string, number[]>(),
    errors: new Map<string, number>(),
    usage: new Map<string, number>(),
  }

  recordLatency(operation: string, duration: number): void {
    const latencies = this.metrics.latency.get(operation) || []
    latencies.push(duration)
    
    // Keep only last 1000 measurements
    if (latencies.length > 1000) {
      latencies.shift()
    }
    
    this.metrics.latency.set(operation, latencies)
  }

  recordError(operation: string, error: Error): void {
    const count = this.metrics.errors.get(operation) || 0
    this.metrics.errors.set(operation, count + 1)
    
    // Log to external service
    console.error(`AI Error in ${operation}:`, error)
  }

  getPercentile(operation: string, percentile: number): number {
    const latencies = this.metrics.latency.get(operation) || []
    if (latencies.length === 0) return 0
    
    const sorted = [...latencies].sort((a, b) => a - b)
    const index = Math.ceil((percentile / 100) * sorted.length) - 1
    
    return sorted[index]
  }
}
```

## Best Practices Summary
1. Always implement retry logic with exponential backoff
2. Cache responses based on semantic similarity
3. Choose models based on task complexity
4. Stream responses for better UX
5. Monitor costs and set up alerts
6. Implement privacy guards for sensitive data
7. Use queuing for rate limit management
8. Track detailed metrics for optimization
9. Plan for graceful degradation
10. Keep AI features optional/enhancing, not critical