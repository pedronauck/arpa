## Core Principles
- Design for reliability - AI APIs can fail or be slow
- Implement graceful degradation for AI features
- Cost-conscious implementation - every token counts
- Privacy-first approach - handle user data responsibly

## API Integration Setup
- Use official SDK for type safety and best practices
- Configure multiple models for different use cases
- Implement proper authentication and key management
- Set up environment-specific configurations
```typescript
// config/ai.ts
import { MastraAI } from '@mastra/sdk'

// Model configuration based on use case
export const AI_MODELS = {
  fast: 'gpt-3.5-turbo',      // Quick responses, low cost
  balanced: 'gpt-4',           // General purpose
  advanced: 'gpt-4-turbo',     // Complex reasoning
  vision: 'gpt-4-vision',      // Image analysis
  embedding: 'text-embedding-3-small', // Semantic search
} as const

// Initialize with environment-specific config
export const ai = new MastraAI({
  apiKey: process.env.MASTRA_API_KEY!,
  organization: process.env.MASTRA_ORG_ID,
  maxRetries: 3,
  timeout: 30000, // 30 seconds
})

// Model router for intelligent selection
export function selectModel(task: TaskType): string {
  switch (task.complexity) {
    case 'simple':
      return AI_MODELS.fast
    case 'complex':
      return AI_MODELS.advanced
    case 'visual':
      return AI_MODELS.vision
    default:
      return AI_MODELS.balanced
  }
}
