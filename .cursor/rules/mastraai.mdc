## Streaming Responses
- Stream for better UX on long responses
- Handle connection interruptions
- Implement progress indicators
- Buffer partial responses appropriately
```typescript
// hooks/useAIStream.ts
import { useCallback, useState } from 'react'

interface UseAIStreamOptions {
  onToken?: (token: string) => void
  onComplete?: (fullResponse: string) => void
  onError?: (error: Error) => void
}

export function useAIStream(options: UseAIStreamOptions = {}) {
  const [isStreaming, setIsStreaming] = useState(false)
  const [response, setResponse] = useState('')
  const [error, setError] = useState<Error | null>(null)

  const stream = useCallback(async (
    prompt: string,
    model: string = AI_MODELS.balanced
  ) => {
    setIsStreaming(true)
    setResponse('')
    setError(null)

    try {
      const stream = await ai.chat.completions.create({
        model,
        messages: [{ role: 'user', content: prompt }],
        stream: true,
        temperature: 0.7,
      })

      let fullResponse = ''
      
      for await (const chunk of stream) {
        const token = chunk.choices[0]?.delta?.content || ''
        fullResponse += token
        
        setResponse(fullResponse)
        options.onToken?.(token)
      }

      options.onComplete?.(fullResponse)
    } catch (err) {
      const error = err as Error
      setError(error)
      options.onError?.(error)
    } finally {
      setIsStreaming(false)
    }
  }, [options])

  return {
    stream,
    response,
    isStreaming,
    error,
  }
}
```

## Security & Privacy
- Never send PII without user consent
- Implement data anonymization
- Use secure key storage
- Audit AI interactions
```typescript
// utils/data-privacy.ts
export class PrivacyGuard {
  private patterns = {
    email: /\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Z|a-z]{2,}\b/g,
    phone: /\b\d{3}[-.]?\d{3}[-.]?\d{4}\b/g,
    ssn: /\b\d{3}-\d{2}-\d{4}\b/g,
    creditCard: /\b\d{4}[\s-]?\d{4}[\s-]?\d{4}[\s-]?\d{4}\b/g,
    // Add more patterns as needed
  }

  anonymize(text: string): string {
    let anonymized = text
    
    // Replace emails
    anonymized = anonymized.replace(this.patterns.email, '[EMAIL]')
    
    // Replace phone numbers
    anonymized = anonymized.replace(this.patterns.phone, '[PHONE]')
    
    // Replace SSNs
    anonymized = anonymized.replace(this.patterns.ssn, '[SSN]')
    
    // Replace credit cards
    anonymized = anonymized.replace(this.patterns.creditCard, '[CC]')
    
    return anonymized
  }

  async audit(
    userId: string,
    action: string,
    data: Record<string, any>
  ): Promise<void> {
    await db.aiAuditLog.create({
      userId,
      action,
      timestamp: new Date(),
      metadata: {
        ...data,
        // Don't log sensitive data
        prompt: data.prompt ? this.anonymize(data.prompt) : undefined,
      },
    })
  }
}
