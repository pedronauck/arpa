{
    "$schema": "https://turborepo.com/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
        },
        "dev": {
            "persistent": true,
            "cache": false
        },
        "typecheck": {
            "dependsOn": ["^typecheck"],
            "outputs": ["**/*.d.ts"]
        },
        "lint": {
            "dependsOn": ["^lint"]
        },
        "format": {
            "dependsOn": ["^format"]
        },
        "test": {
            "dependsOn": ["^test"]
        },
        "clean": {
            "cache": false
        }
    }
}
